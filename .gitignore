# Environment / secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
*.log
.venv/
.venv*/
venv/

# SQLite / local artifacts
museum_guide.db
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# Generated Flutter asset copies (created by setup)
# ignore generated asset contents, but keep placeholders
assets/database/
assets/audio/
!assets/database/.gitkeep
!assets/audio/.gitkeep

# Flutter / Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
build/
*.g.dart

# Platform folders (do not commit platform-specific builds)
android/
ios/
linux/
macos/
web/
windows/

# iOS extras (kept for parity but platform dir ignored above)
# (kept for reference)

# IDE / OS
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db

# Keep lockfiles local
pubspec.lock

# Keep IDE and local metadata out
.metadata
